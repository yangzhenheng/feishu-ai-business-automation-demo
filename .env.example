# App
APP_NAME=Feishu AI Business Automation Demo
APP_ENV=local
DATABASE_PATH=./business_demo.db
DATABASE_URL=sqlite:///data/app.db

# Optional: Feishu custom bot webhook
FEISHU_WEBHOOK_URL=

# Feishu Bitable mock/real switch. Default mock mode is safe for local demos.
FEISHU_ENABLE_REAL_API=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_TABLE_ORDERS=
FEISHU_TABLE_INVENTORY=
FEISHU_TABLE_EXCEPTIONS=
FEISHU_TABLE_LEADS=
FEISHU_TABLE_REPORTS=

# Optional: WeCom / 企业微信 group bot webhook
WECHAT_WORK_WEBHOOK_URL=

# Optional: OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
